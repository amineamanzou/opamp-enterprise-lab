# Plaintext input template. Fill locally, encrypt with task secrets:encrypt:elastic,
# then delete or keep only in gitignored secrets/.
ELASTIC_OTLP_ENDPOINT=https://replace-me.elastic-cloud.com
ELASTIC_API_KEY=replace-me

# Optional for Elastic visibility as code.
# ELASTICSEARCH_URL can be omitted when it can be derived from ELASTIC_OTLP_ENDPOINT.
ELASTICSEARCH_URL=https://replace-me.es.elastic-cloud.com
KIBANA_URL=https://replace-me.kb.elastic-cloud.com
KIBANA_SPACE=default
ELASTIC_ONBOARDING_ID=00000000-0000-0000-0000-000000000000
