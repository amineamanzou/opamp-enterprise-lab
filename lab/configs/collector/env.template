# Elastic Cloud OTLP/HTTP target. Do not commit filled values.
ELASTIC_OTLP_ENDPOINT=https://REPLACE_WITH_ELASTIC_OTLP_ENDPOINT
ELASTIC_API_KEY=REPLACE_WITH_ELASTIC_API_KEY

# Collector listener and health endpoints.
OTEL_OTLP_GRPC_ENDPOINT=0.0.0.0:4317
OTEL_OTLP_HTTP_ENDPOINT=0.0.0.0:4318
OTEL_HEALTH_CHECK_ENDPOINT=0.0.0.0:13133

# Filelog source. Use a comma-separated include list only if your shell/runtime expands it as YAML.
LOG_FILE_PATHS=/var/log/poc/*.log

# Resource attributes.
SERVICE_NAME=opamp-logs-poc
DEPLOYMENT_ENVIRONMENT=lab
POC_NAME=opamp-fleet-logs
ELASTIC_ONBOARDING_ID=00000000-0000-0000-0000-000000000000

# Runtime tuning.
OTEL_LOG_LEVEL=info
OTEL_MEMORY_LIMIT_MIB=256
OTEL_MEMORY_SPIKE_LIMIT_MIB=64
OTEL_BATCH_TIMEOUT=1s
OTEL_BATCH_SEND_SIZE=1024
OTEL_BATCH_SEND_MAX_SIZE=2048
ELASTIC_EXPORT_TIMEOUT=30s
OTEL_EXPORT_TIMEOUT=30s
OTEL_EXPORT_QUEUE_CONSUMERS=4
OTEL_EXPORT_QUEUE_SIZE=8192

# OpAMP variant only.
OPAMP_SERVER_WS_ENDPOINT=ws://127.0.0.1:4320/v1/opamp
OPAMP_AUTH_TOKEN=REPLACE_WITH_LOCAL_OR_LAB_TOKEN
OPAMP_RING=dev
OPAMP_AGENT_EXECUTABLE=./otelcol-logs-opamp
OPAMP_AGENT_CONFIG_FILE=./logs-opamp-elastic.yaml
