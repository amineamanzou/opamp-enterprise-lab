{
  "rules": [
    {
      "rule_id": "opamp-lab-kubernetes-audit-sensitive-verbs",
      "name": "OpAMP lab: Kubernetes audit sensitive verbs",
      "description": "Highlights create, update, patch, delete, and deletecollection audit events captured from the k3s lab API server.",
      "enabled": true,
      "type": "query",
      "language": "kuery",
      "index": ["logs-security.kubernetes_audit.otel-*"],
      "query": "data_stream.dataset: \"security.kubernetes_audit.otel\" and attributes.verb: (\"create\" or \"update\" or \"patch\" or \"delete\" or \"deletecollection\")",
      "from": "now-10m",
      "interval": "5m",
      "severity": "medium",
      "risk_score": 47,
      "tags": ["opamp-poc", "kubernetes", "audit"],
      "actions": []
    },
    {
      "rule_id": "opamp-lab-kubernetes-audit-forbidden",
      "name": "OpAMP lab: Kubernetes audit forbidden responses",
      "description": "Detects forbidden Kubernetes API responses in the regulated observability lab.",
      "enabled": true,
      "type": "query",
      "language": "kuery",
      "index": ["logs-security.kubernetes_audit.otel-*"],
      "query": "data_stream.dataset: \"security.kubernetes_audit.otel\" and attributes.responseStatus.code: 403",
      "from": "now-10m",
      "interval": "5m",
      "severity": "high",
      "risk_score": 73,
      "tags": ["opamp-poc", "kubernetes", "audit", "forbidden"],
      "actions": []
    },
    {
      "rule_id": "opamp-lab-host-security-events",
      "name": "OpAMP lab: Host security events",
      "description": "Surfaces host authentication and security events exported by the supervised OTel collector.",
      "enabled": true,
      "type": "query",
      "language": "kuery",
      "index": ["logs-security.host.otel-*"],
      "query": "data_stream.dataset: \"security.host.otel\"",
      "from": "now-10m",
      "interval": "5m",
      "severity": "low",
      "risk_score": 21,
      "tags": ["opamp-poc", "host", "security"],
      "actions": []
    },
    {
      "rule_id": "opamp-lab-collector-export-failures",
      "name": "OpAMP lab: Collector export failures",
      "description": "Detects OpenTelemetry Collector receiver failure or refusal metrics for the Elastic telemetry path.",
      "enabled": true,
      "type": "query",
      "language": "kuery",
      "index": ["metrics-metrics.collector.otel-*"],
      "query": "data_stream.dataset: \"metrics.collector.otel\" and (metrics.otelcol_receiver_failed_log_records_total > 0 or metrics.otelcol_receiver_refused_log_records_total > 0 or metrics.otelcol_receiver_failed_metric_points_total > 0 or metrics.otelcol_receiver_refused_metric_points_total > 0)",
      "from": "now-10m",
      "interval": "5m",
      "severity": "medium",
      "risk_score": 55,
      "tags": ["opamp-poc", "collector", "observability"],
      "actions": []
    },
    {
      "rule_id": "opamp-lab-opamp-limited-metadata",
      "name": "OpAMP lab: Agent connected with limited metadata",
      "description": "Detects OpAMP agents that are connected but do not expose enough metadata for useful operations inventory.",
      "enabled": true,
      "type": "query",
      "language": "kuery",
      "index": ["logs-opamp.inventory-*"],
      "query": "data_stream.dataset: \"opamp.inventory\" and agent.connected: true and agent.limited_metadata: true",
      "from": "now-30m",
      "interval": "10m",
      "severity": "medium",
      "risk_score": 42,
      "tags": ["opamp-poc", "opamp", "inventory"],
      "actions": []
    },
    {
      "rule_id": "opamp-lab-agent-disconnected",
      "name": "OpAMP lab: Agent disconnected",
      "description": "Detects OpAMP agent disconnection events emitted by the vanilla server.",
      "enabled": true,
      "type": "query",
      "language": "kuery",
      "index": ["logs-opamp.events-*"],
      "query": "data_stream.dataset: \"opamp.events\" and event.action: \"agent.disconnected\"",
      "from": "now-10m",
      "interval": "5m",
      "severity": "medium",
      "risk_score": 50,
      "tags": ["opamp-poc", "opamp", "lifecycle"],
      "actions": []
    },
    {
      "rule_id": "opamp-lab-agent-downgrade",
      "name": "OpAMP lab: Agent downgrade",
      "description": "Detects collector or agent version downgrade events.",
      "enabled": true,
      "type": "query",
      "language": "kuery",
      "index": ["logs-opamp.events-*"],
      "query": "data_stream.dataset: \"opamp.events\" and event.action: \"agent.version_changed\" and agent.version_direction: \"downgrade\"",
      "from": "now-30m",
      "interval": "10m",
      "severity": "high",
      "risk_score": 70,
      "tags": ["opamp-poc", "opamp", "version"],
      "actions": []
    },
    {
      "rule_id": "opamp-lab-config-error",
      "name": "OpAMP lab: Remote config error",
      "description": "Detects failed remote configuration status changes reported by OpAMP agents.",
      "enabled": true,
      "type": "query",
      "language": "kuery",
      "index": ["logs-opamp.events-*"],
      "query": "data_stream.dataset: \"opamp.events\" and event.action: \"agent.config_status_changed\" and agent.current_status: *error*",
      "from": "now-30m",
      "interval": "10m",
      "severity": "high",
      "risk_score": 75,
      "tags": ["opamp-poc", "opamp", "config"],
      "actions": []
    }
  ]
}
