# Copy to terraform.tfvars for real use. terraform.tfvars is gitignored.
# Never commit Hetzner tokens, private keys, kubeconfigs, or OpAMP enrollment secrets.

project_name = "opamp-enterprise-lab"
location     = "fsn1"
image        = "ubuntu-24.04"
server_type  = "cx23"

# Prefer setting the token outside this file:
# export TF_VAR_hcloud_token="..."

# Use one of these SSH key modes:
# ssh_key_name = "existing-hcloud-key-name"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# Narrow this to your current IP/CIDR before applying.
allowed_ssh_cidrs       = ["203.0.113.10/32"]
allowed_http_cidrs      = ["203.0.113.10/32"]
allowed_opamp_cidrs     = ["203.0.113.10/32"]
allowed_admin_api_cidrs = ["203.0.113.10/32"]
allowed_otlp_cidrs      = ["203.0.113.10/32"]
allowed_k3s_api_cidrs   = ["203.0.113.10/32", "10.42.0.0/16"]
allowed_k3s_peer_cidrs  = []

enable_optional_load_host = false
enable_host_agent_vm      = true
enable_kubernetes_vms     = true
public_ipv4_enabled       = true
public_ipv6_enabled       = true

labels = {
  owner       = "platform"
  cost-center = "lab"
}
