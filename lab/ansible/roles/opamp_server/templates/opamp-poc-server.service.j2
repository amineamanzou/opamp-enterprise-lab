[Unit]
Description=OpAMP POC Server
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
EnvironmentFile={{ opamp_config_dir }}/opamp-server.env
ExecStart={{ opamp_binary_remote_path }}
Restart=on-failure
RestartSec=5s
User=root
WorkingDirectory={{ opamp_data_dir }}

[Install]
WantedBy=multi-user.target
