#!/usr/bin/env python3
import argparse
import json
import random
import time
from datetime import datetime, timezone


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--path", default="{{ synthetic_log_path }}")
    parser.add_argument("--rate", type=float, default={{ synthetic_log_rate_per_second }})
    args = parser.parse_args()

    delay = 1.0 / max(args.rate, 0.1)
    levels = ["INFO", "WARN", "ERROR"]
    services = ["checkout", "billing", "inventory", "edge"]

    while True:
        event = {
            "ts": datetime.now(timezone.utc).isoformat(),
            "level": random.choices(levels, weights=[85, 10, 5])[0],
            "service": random.choice(services),
            "message": "synthetic fleet event",
            "latency_ms": random.randint(5, 1500),
        }
        with open(args.path, "a", encoding="utf-8") as stream:
            stream.write(json.dumps(event, separators=(",", ":")) + "\n")
        time.sleep(delay)


if __name__ == "__main__":
    main()
